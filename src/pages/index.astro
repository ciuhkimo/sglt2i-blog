---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const sglt2iNotes = await getCollection('sglt2i');
const glp1raNotes = await getCollection('glp1ra');
const patientNotes = await getCollection('patient');
const dialysisNotes = await getCollection('dialysis');
const blogNotes = await getCollection('blog');

const sections = [
	{
		title: 'SGLT2i 決策筆記',
		description: 'SGLT2 inhibitor 在 CKD 與心腎保護的 20 個臨床決策問題。涵蓋啟用時機、風險評估、監測判讀、暫停重啟與特殊族群。',
		count: sglt2iNotes.length,
		unit: '篇',
		href: '/sglt2i/',
		color: '#e8f4f0',
		accent: 'var(--accent)',
		icon: '💊',
	},
	{
		title: 'GLP-1 RA 決策筆記',
		description: 'GLP-1 receptor agonist 在 CKD 與心腎保護的 10 個臨床決策問題。以 FLOW trial 為核心，涵蓋啟用、排序、安全性與四柱整合。',
		count: glp1raNotes.length,
		unit: '篇（建置中）',
		href: '/glp1ra/',
		color: '#fef5e7',
		accent: '#d4913a',
		icon: '💉',
	},
	{
		title: '給病人與家屬',
		description: '用白話中文說明腎臟用藥的常見問題，幫助病人和家屬在看診前後更了解自己的治療。',
		count: patientNotes.length,
		unit: '篇',
		href: '/patient/',
		color: '#f0f4ff',
		accent: '#4a6fa5',
		icon: '👨‍👩‍👧',
	},
	{
		title: '透析衛教——護理版',
		description: '以護理實務為導向的透析照護學習筆記。涵蓋併發症處理、飲食營養、水分控制、感染預防等核心主題。',
		count: dialysisNotes.length,
		unit: '篇',
		href: '/dialysis/',
		color: '#f5f3ef',
		accent: '#8b7355',
		icon: '🏥',
	},
	{
		title: '臨床專題',
		description: '針對特定臨床情境的深度整理——透析掉髮、台灣腎病趨勢等教科書著墨不多的實務問題。',
		count: blogNotes.length,
		unit: '篇',
		href: '/blog/',
		color: '#f3f0f5',
		accent: '#7a5ea7',
		icon: '📋',
	},
];
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 880px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}

			/* Hero */
			.hero {
				text-align: center;
				margin-bottom: 3em;
				padding: 2em 0;
			}
			.hero h1 {
				font-size: 2.4em;
				margin-bottom: 0.3em;
				color: var(--accent-dark);
			}
			.hero .tagline {
				font-size: 1.15em;
				color: rgb(var(--gray));
				max-width: 600px;
				margin: 0 auto 1.5em;
				line-height: 1.7;
			}
			.hero .stats {
				display: flex;
				justify-content: center;
				gap: 2em;
				flex-wrap: wrap;
				font-size: 0.9em;
				color: rgb(var(--gray));
			}
			.hero .stat-num {
				font-size: 1.8em;
				font-weight: 700;
				color: var(--accent-dark);
				display: block;
			}

			/* Cards grid */
			.cards {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5em;
				margin-bottom: 3em;
			}
			.card {
				border-radius: 10px;
				padding: 1.8em;
				text-decoration: none;
				color: rgb(var(--gray-dark));
				transition: transform 0.15s, box-shadow 0.15s;
				display: flex;
				flex-direction: column;
			}
			.card:hover {
				transform: translateY(-3px);
				box-shadow: 0 6px 20px rgba(0,0,0,0.1);
				color: rgb(var(--gray-dark));
			}
			.card-icon {
				font-size: 2em;
				margin-bottom: 0.5em;
			}
			.card h2 {
				font-size: 1.25em;
				margin-bottom: 0.4em;
			}
			.card .card-desc {
				font-size: 0.9em;
				color: rgb(var(--gray));
				line-height: 1.6;
				flex-grow: 1;
			}
			.card .card-count {
				margin-top: 1em;
				font-size: 0.85em;
				font-weight: 600;
			}
			.card .card-cta {
				margin-top: 0.8em;
				font-size: 0.9em;
				font-weight: 600;
			}

			/* About preview */
			.about-preview {
				text-align: center;
				padding: 2.5em 1em;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.about-preview .author {
				font-size: 1.1em;
				font-weight: 600;
				color: rgb(var(--gray-dark));
				margin-bottom: 0.5em;
			}
			.about-preview p {
				font-size: 0.95em;
				color: rgb(var(--gray));
				max-width: 550px;
				margin: 0 auto 1em;
				line-height: 1.7;
			}
			.about-preview a {
				color: var(--accent);
				text-decoration: none;
				font-weight: 600;
			}
			.about-preview a:hover {
				text-decoration: underline;
			}

			@media (max-width: 720px) {
				.hero h1 {
					font-size: 1.8em;
				}
				.cards {
					grid-template-columns: 1fr;
				}
				.hero .stats {
					gap: 1.2em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Nephro Decisions</h1>
				<p class="tagline">腎臟科臨床決策知識庫——從實證到實務，涵蓋藥物決策、透析照護與病人衛教。由腎臟科專科醫師主導，AI 輔助研究與多輪交替審稿。</p>
				<div class="stats">
					<div><span class="stat-num">{sglt2iNotes.length + glp1raNotes.length}</span>決策筆記</div>
					<div><span class="stat-num">{patientNotes.length}</span>病人衛教</div>
					<div><span class="stat-num">{dialysisNotes.length}</span>透析護理</div>
					<div><span class="stat-num">{blogNotes.length}</span>臨床專題</div>
				</div>
			</section>

			<div class="cards">
				{sections.map((s) => (
					<a class="card" href={s.href} style={`background: ${s.color};`}>
						<span class="card-icon">{s.icon}</span>
						<h2>{s.title}</h2>
						<p class="card-desc">{s.description}</p>
						<span class="card-count" style={`color: ${s.accent};`}>{s.count} {s.unit}</span>
						<span class="card-cta" style={`color: ${s.accent};`}>前往 →</span>
					</a>
				))}
			</div>

			<section class="about-preview">
				<p class="author">小鎮醫生｜腎臟科專科醫師｜內科專科醫師｜台灣大學醫學系</p>
				<p>每篇筆記經過臨床問題定義、多平台文獻研究、AI 與人工交替審稿的九步驟流程產出。內容以實證為基礎，結合台灣臨床實務。</p>
				<a href="/about/">了解更多 →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
