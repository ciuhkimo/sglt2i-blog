---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');

const clusters = [
	{
		title: '啟用決策 (Initiation)',
		description: 'KDIGO 2024 已將 SGLT2i 定位為 CKD 的核心器官保護藥物，而非僅是血糖藥。但臨床上「該不該開」仍是最常見的猶豫點：非糖尿病 CKD 能不能用？eGFR 掉到 20-30 還敢開嗎？蛋白尿不高的病人有沒有效益？心臟保護和腎臟保護是同一回事嗎？這五篇筆記涵蓋啟用時機、適應症邊界、與 eGFR 門檻的實證決策。',
		prefix: ['Q01', 'Q02', 'Q03', 'Q04', 'Q05'],
	},
	{
		title: '風險評估 (Risk Assessment)',
		description: '開藥前最怕的三件事：病人會不會 DKA、會不會脫水低血壓、反覆泌尿道或生殖器感染怎麼辦？加上手術前到底要停幾天，FDA 和英國指引還講不同天數。這四篇筆記整理了啟用前的體液評估框架、DKA 高風險辨識清單、感染風險的效益權衡、以及圍術期停藥的國際共識比較。',
		prefix: ['Q06', 'Q07', 'Q08', 'Q09'],
	},
	{
		title: '監測判讀 (Monitoring)',
		description: '啟用 SGLT2i 後最常觸發停藥焦慮的，不是真正的副作用，而是對正常生理反應的誤判。Creatinine 上升是 hemodynamic dip 還是 AKI？eGFR 掉了 15% 要不要停？血壓降了是 SGLT2i 還是利尿劑？病人說尿多口渴是脫水嗎？這四篇提供可操作的鑑別診斷框架，避免不必要的停藥。',
		prefix: ['Q10', 'Q11', 'Q12', 'Q13'],
	},
	{
		title: '暫停與重啟 (Hold & Restart)',
		description: '急性疾病住院、AKI、手術——這些情境下 SGLT2i 該暫停還是繼續？停了之後什麼時候重啟？太早重啟怕出事，太晚重啟浪費保護效益。這五篇筆記整理了 sick day rules、AKI 分級對應的停藥邏輯、術前停藥天數、以及恢復後重啟的臨床條件清單。',
		prefix: ['Q14', 'Q15', 'Q16', 'Q17', 'Q18'],
	},
	{
		title: '整合與特殊族群 (Integration)',
		description: 'CKD 病人常同時使用 ACEi/ARB、可能需要加上 finerenone 或 GLP-1 RA——這些藥怎麼疊加、順序怎麼排？另外，78 歲衰弱老人、腎移植後 5 年的糖尿病患者、即將進入透析的病人，這些主要 RCT 代表性不足的族群到底能不能用？這兩篇處理多重藥物整合策略與特殊族群的個別化決策。',
		prefix: ['Q19', 'Q20'],
	},
];
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			.site-intro {
				margin-bottom: 2.5em;
			}
			.site-intro h1 {
				font-size: 2.2em;
				margin-bottom: 0.3em;
			}
			.site-intro p {
				color: rgb(var(--gray));
				font-size: 1.05em;
			}
			.cluster {
				margin-bottom: 2.5em;
			}
			.cluster h2 {
				font-size: 1.5em;
				margin-bottom: 0.3em;
				border-left: 4px solid var(--accent);
				padding-left: 0.5em;
			}
			.cluster .cluster-desc {
				color: rgb(var(--gray));
				font-size: 0.95em;
				margin-bottom: 0.8em;
			}
			.note-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.note-list li {
				padding: 0.4em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.note-list li:last-child {
				border-bottom: none;
			}
			.note-list a {
				text-decoration: none;
				display: flex;
				justify-content: space-between;
				align-items: baseline;
			}
			.note-list a:hover {
				color: var(--accent);
			}
			.note-id {
				font-weight: 700;
				margin-right: 0.5em;
				color: var(--accent-dark);
			}
			.note-version {
				font-size: 0.8em;
				color: rgb(var(--gray));
			}
			.placeholder {
				color: rgb(var(--gray));
				font-size: 0.9em;
				font-style: italic;
				padding: 0.5em 0;
			}
			.patient-section {
				margin-top: 3em;
				padding: 2em;
				background: var(--accent-light, #e8f4f0);
				border-radius: 8px;
			}
			.patient-section h2 {
				font-size: 1.5em;
				margin-bottom: 0.3em;
			}
			.patient-section p {
				color: rgb(var(--gray));
				font-size: 0.95em;
				margin-bottom: 1em;
			}
			.patient-link {
				display: inline-block;
				background: var(--accent);
				color: #fff;
				padding: 0.5em 1.2em;
				border-radius: 6px;
				text-decoration: none;
				font-size: 0.95em;
				font-weight: 600;
			}
			.patient-link:hover {
				background: var(--accent-dark);
				color: #fff;
			}
			.dialysis-section {
				margin-top: 2em;
				padding: 2em;
				background: #f5f3ef;
				border-radius: 8px;
			}
			.dialysis-section h2 {
				font-size: 1.5em;
				margin-bottom: 0.3em;
			}
			.dialysis-section p {
				color: rgb(var(--gray));
				font-size: 0.95em;
				margin-bottom: 1em;
			}
			.dialysis-link {
				display: inline-block;
				background: var(--accent);
				color: #fff;
				padding: 0.5em 1.2em;
				border-radius: 6px;
				text-decoration: none;
				font-size: 0.95em;
				font-weight: 600;
			}
			.dialysis-link:hover {
				background: var(--accent-dark);
				color: #fff;
			}
			.blog-section {
				margin-top: 2em;
				padding: 2em;
				background: #f3f0f5;
				border-radius: 8px;
			}
			.blog-section h2 {
				font-size: 1.5em;
				margin-bottom: 0.3em;
			}
			.blog-section p {
				color: rgb(var(--gray));
				font-size: 0.95em;
				margin-bottom: 1em;
			}
			.blog-link {
				display: inline-block;
				background: var(--accent);
				color: #fff;
				padding: 0.5em 1.2em;
				border-radius: 6px;
				text-decoration: none;
				font-size: 0.95em;
				font-weight: 600;
			}
			.blog-link:hover {
				background: var(--accent-dark);
				color: #fff;
			}
			.disclaimer {
				margin-top: 3em;
				padding-top: 1.5em;
				border-top: 1px solid rgb(var(--gray-light));
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="site-intro">
				<h1>{SITE_TITLE}</h1>
				<p>{SITE_DESCRIPTION}</p>
			</section>

			{clusters.map((cluster) => {
				const clusterNotes = allNotes
					.filter((n) => cluster.prefix.includes(n.data.question_id))
					.sort((a, b) => a.data.question_id.localeCompare(b.data.question_id));
				return (
					<section class="cluster">
						<h2>{cluster.title}</h2>
						<p class="cluster-desc">{cluster.description}</p>
						{clusterNotes.length > 0 ? (
							<ul class="note-list">
								{clusterNotes.map((note) => (
									<li>
										<a href={`/notes/${note.id}/`}>
											<span>
												<span class="note-id">{note.data.question_id}</span>
												{note.data.title}
											</span>
											<span class="note-version">{note.data.version}</span>
										</a>
									</li>
								))}
							</ul>
						) : (
							<p class="placeholder">筆記準備中...</p>
						)}
					</section>
				);
			})}

			<section class="patient-section">
				<h2>給病人與家屬</h2>
				<p>用白話中文說明 SGLT2 抑制劑常見問題。這些文章不取代醫師的診療建議，而是幫助您在看診前後更了解自己的用藥。</p>
				<a href="/patient/" class="patient-link">前往病人衛教專區 &rarr;</a>
			</section>

			<section class="dialysis-section">
				<h2>透析衛教——護理版</h2>
				<p>以護理實務為導向的透析照護學習筆記。涵蓋血液透析併發症處理、飲食營養、水分控制、糖尿病照護、貧血管理、骨礦物質代謝等核心主題。</p>
				<a href="/dialysis/" class="dialysis-link">前往透析衛教專區 &rarr;</a>
			</section>

			<section class="blog-section">
				<h2>臨床專題</h2>
				<p>針對特定臨床情境的深度整理，涵蓋腎臟科常見但教科書著墨不多的實務問題。</p>
				<a href="/blog/" class="blog-link">前往臨床專題 &rarr;</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
