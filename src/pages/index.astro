---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const sglt2iNotes = await getCollection('sglt2i');
const glp1raNotes = await getCollection('glp1ra');
const finerenoneNotes = await getCollection('finerenone');
const ckmNotes = await getCollection('ckm');
const sexualHealthNotes = await getCollection('sexualHealth');
const patientNotes = await getCollection('patient');
const dialysisNotes = await getCollection('dialysis');
const blogNotes = await getCollection('blog');

const totalDecisionNotes = sglt2iNotes.length + glp1raNotes.length + finerenoneNotes.length + ckmNotes.length;
const totalAll = totalDecisionNotes + sexualHealthNotes.length + patientNotes.length + dialysisNotes.length + blogNotes.length;

const groups = [
	{
		title: '藥物決策',
		subtitle: '腎臟科核心藥物的臨床決策問題，從啟用到停藥的完整思路。',
		cards: [
			{
				title: 'SGLT2i 決策筆記',
				description: '20 個臨床決策問題。涵蓋啟用時機、風險評估、監測判讀、暫停重啟與特殊族群。',
				count: sglt2iNotes.length,
				unit: '篇',
				href: '/sglt2i/',
				color: '#e8f4f0',
				accent: 'var(--accent)',
				icon: '💊',
			},
			{
				title: 'GLP-1 RA 決策筆記',
				description: '10 個臨床決策問題。以 FLOW trial 為核心，涵蓋啟用、排序、安全性與四柱整合。',
				count: glp1raNotes.length,
				unit: '篇',
				href: '/glp1ra/',
				color: '#fef5e7',
				accent: '#8a5c10',
				icon: '💉',
			},
			{
				title: 'Finerenone 決策筆記',
				description: '11 個臨床決策問題。整合 FIDELIO、FIGARO、FIDELITY、CONFIDENCE 證據，涵蓋啟用、排序、高血鉀管理與台灣健保實務。',
				count: finerenoneNotes.length,
				unit: '篇',
				href: '/finerenone/',
				color: '#eef0f7',
				accent: '#4a5699',
				icon: '🛡️',
			},
		],
	},
	{
		title: '臨床專區',
		subtitle: '針對特定臨床主題的系統性深度整理。',
		cards: [
			{
				title: 'CKM Syndrome 決策筆記',
				description: '15 個心腎代謝症候群的臨床決策問題。涵蓋 CKM 分期、心腎交互、代謝手術、四柱整合與風險分層。',
				count: ckmNotes.length,
				unit: '篇',
				href: '/ckm/',
				color: '#f0e8f5',
				accent: '#634a8a',
				icon: '\u{1FAC0}',
			},
			{
				title: '腎友與性',
				description: '透析病人的性功能、月經、生育與親密關係。涵蓋病人衛教與臨床決策筆記，男女都有。',
				count: sexualHealthNotes.length,
				unit: '篇',
				href: '/sexual-health/',
				color: '#fce4ec',
				accent: '#9b4060',
				icon: '❤️‍🩹',
			},
			{
				title: '臨床專題',
				description: '教科書著墨不多的實務問題——透析掉髮、台灣腎病趨勢等。',
				count: blogNotes.length,
				unit: '篇',
				href: '/blog/',
				color: '#f3f0f5',
				accent: '#634a8a',
				icon: '📋',
			},
		],
	},
	{
		title: '衛教資源',
		subtitle: '用白話中文，讓病人、家屬與護理團隊都能用的學習資源。',
		cards: [
			{
				title: '給病人與家屬',
				description: '用白話中文說明腎臟用藥的常見問題，幫助病人和家屬在看診前後更了解自己的治療。',
				count: patientNotes.length,
				unit: '篇',
				href: '/patient/',
				color: '#f0f4ff',
				accent: '#4a6fa5',
				icon: '👨‍👩‍👧',
			},
			{
				title: '透析衛教——護理版',
				description: '以護理實務為導向的透析照護學習筆記。涵蓋併發症處理、飲食營養、水分控制、感染預防。',
				count: dialysisNotes.length,
				unit: '篇',
				href: '/dialysis/',
				color: '#f5f3ef',
				accent: '#6e5a3f',
				icon: '🏥',
			},
		],
	},
];
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'WebSite',
			name: 'Nephro Decisions',
			url: 'https://nephrodecisions.com/',
			description: '腎臟科臨床決策知識庫——從實證到實務，涵蓋藥物決策、透析照護與病人衛教。',
			inLanguage: 'zh-Hant',
			publisher: {
				'@type': 'Person',
				name: '小鎮醫生',
				jobTitle: '腎臟科專科醫師',
				affiliation: { '@type': 'Organization', name: '台灣大學醫學系' },
				url: 'https://nephrodecisions.com/about/',
			},
		})} />
		<style>
			main {
				width: 880px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}

			/* Hero */
			.hero {
				text-align: center;
				margin-bottom: 3em;
				padding: 2em 0;
			}
			.hero h1 {
				font-size: 2.4em;
				margin-bottom: 0.3em;
				color: var(--accent-dark);
			}
			.hero .tagline {
				font-size: 1.15em;
				color: rgb(var(--gray));
				max-width: 600px;
				margin: 0 auto 1.5em;
				line-height: 1.7;
			}
			.hero .stats {
				display: flex;
				justify-content: center;
				gap: 2em;
				flex-wrap: wrap;
				font-size: 0.9em;
				color: rgb(var(--gray));
			}
			.hero .stat-num {
				font-size: 1.8em;
				font-weight: 700;
				color: var(--accent-dark);
				display: block;
			}

			/* Section groups */
			.section-group {
				margin-bottom: 2.5em;
			}
			.section-group-header {
				margin-bottom: 1em;
			}
			.section-group-header h2 {
				font-size: 1.4em;
				color: var(--accent-dark);
				margin: 0 0 0.2em;
				border-left: 4px solid var(--accent);
				padding-left: 0.6em;
			}
			.section-group-header p {
				font-size: 0.9em;
				color: rgb(var(--gray));
				margin: 0;
				padding-left: 1.2em;
			}

			/* Cards grid */
			.cards {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.2em;
			}
			.card {
				border-radius: 10px;
				padding: 1.6em;
				text-decoration: none;
				color: rgb(var(--gray-dark));
				transition: transform 0.15s, box-shadow 0.15s;
				display: flex;
				flex-direction: column;
			}
			.card:hover {
				transform: translateY(-3px);
				box-shadow: 0 6px 20px rgba(0,0,0,0.1);
				color: rgb(var(--gray-dark));
			}
			.card-icon {
				font-size: 1.8em;
				margin-bottom: 0.4em;
			}
			.card h3 {
				font-size: 1.15em;
				margin: 0 0 0.3em;
			}
			.card .card-desc {
				font-size: 0.88em;
				color: rgb(var(--gray));
				line-height: 1.6;
				flex-grow: 1;
			}
			.card .card-count {
				margin-top: 0.8em;
				font-size: 0.85em;
				font-weight: 600;
			}
			.card .card-cta {
				margin-top: 0.5em;
				font-size: 0.9em;
				font-weight: 600;
			}

			/* Subscribe */
			.subscribe-section {
				text-align: center;
				padding: 2.5em 1em;
				margin-bottom: 1em;
				background: #f0f4f3;
				border-radius: 12px;
			}
			.subscribe-section h2 {
				font-size: 1.3em;
				color: var(--accent-dark);
				margin: 0 0 0.3em;
			}
			.subscribe-section > p {
				font-size: 0.95em;
				color: rgb(var(--gray));
				margin: 0 0 1.2em;
			}
			.subscribe-form {
				display: flex;
				justify-content: center;
				gap: 0.5em;
				flex-wrap: wrap;
				max-width: 420px;
				margin: 0 auto;
			}
			.subscribe-form input[type="email"] {
				flex: 1;
				min-width: 200px;
				padding: 0.6em 1em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 6px;
				font-size: 0.95em;
			}
			.subscribe-form button {
				padding: 0.6em 1.5em;
				background: var(--accent);
				color: #fff;
				border: none;
				border-radius: 6px;
				font-size: 0.95em;
				font-weight: 600;
				cursor: pointer;
			}
			.subscribe-form button:hover {
				background: var(--accent-dark);
			}
			.subscribe-note {
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin-top: 0.8em;
			}
			.subscribe-note a {
				color: var(--accent);
			}

			/* About preview */
			.about-preview {
				text-align: center;
				padding: 2.5em 1em;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.about-preview .author {
				font-size: 1.1em;
				font-weight: 600;
				color: rgb(var(--gray-dark));
				margin-bottom: 0.5em;
			}
			.about-preview p {
				font-size: 0.95em;
				color: rgb(var(--gray));
				max-width: 550px;
				margin: 0 auto 1em;
				line-height: 1.7;
			}
			.about-preview a {
				color: var(--accent);
				text-decoration: none;
				font-weight: 600;
			}
			.about-preview a:hover {
				text-decoration: underline;
			}

			@media (max-width: 720px) {
				.hero h1 {
					font-size: 1.8em;
				}
				.cards {
					grid-template-columns: 1fr;
				}
				.hero .stats {
					gap: 1.2em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main-content">
			<section class="hero">
				<h1>Nephro Decisions</h1>
				<p class="tagline">腎臟科臨床決策知識庫——從實證到實務，涵蓋藥物決策、透析照護與病人衛教。由腎臟科專科醫師主導，AI 輔助研究與多輪交替審稿。</p>
				<div class="stats">
					<div><span class="stat-num">{totalAll}</span>篇文章</div>
					<div><span class="stat-num">{totalDecisionNotes}</span>決策筆記</div>
					<div><span class="stat-num">{sexualHealthNotes.length}</span>腎友與性</div>
					<div><span class="stat-num">{patientNotes.length + dialysisNotes.length}</span>衛教資源</div>
				</div>
			</section>

			{groups.map((group) => (
				<section class="section-group">
					<div class="section-group-header">
						<h2>{group.title}</h2>
						<p>{group.subtitle}</p>
					</div>
					<div class="cards">
						{group.cards.map((s) => (
							<a class="card" href={s.href} style={`background: ${s.color};`}>
								<span class="card-icon">{s.icon}</span>
								<h3>{s.title}</h3>
								<p class="card-desc">{s.description}</p>
								<span class="card-count" style={`color: ${s.accent};`}>{s.count} {s.unit}</span>
								<span class="card-cta" style={`color: ${s.accent};`}>前往 →</span>
							</a>
						))}
					</div>
				</section>
			))}

			<section class="subscribe-section">
				<h2>訂閱更新</h2>
				<p>新的臨床決策筆記發布時，直接寄到你的信箱。不灌水、不賣東西。</p>
				<form
					action="https://buttondown.com/api/emails/embed-subscribe/nephrodecisions"
					method="post"
					target="popupwindow"
					class="subscribe-form"
				>
					<label for="home-subscribe-email" class="sr-only">電子郵件地址</label>
					<input type="email" name="email" id="home-subscribe-email" placeholder="your@email.com" required aria-label="電子郵件地址" />
					<button type="submit">訂閱</button>
				</form>
				<p class="subscribe-note">也可透過 <a href="/rss.xml">RSS</a> 追蹤</p>
			</section>

			<section class="about-preview">
				<p class="author">小鎮醫生｜腎臟科專科醫師｜內科專科醫師｜台灣大學醫學系</p>
				<p>每篇筆記經過臨床問題定義、多平台文獻研究、AI 與人工交替審稿的七步驟流程產出。內容以實證為基礎，結合台灣臨床實務。</p>
				<a href="/about/">了解更多 →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
