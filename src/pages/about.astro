---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const profileLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'ProfilePage',
	mainEntity: {
		'@type': 'Person',
		name: '小鎮醫生',
		jobTitle: '腎臟科專科醫師',
		affiliation: {
			'@type': 'Organization',
			name: '台灣大學醫學系',
		},
		description: '腎臟科專科醫師、內科專科醫師。Nephro Decisions 創辦人，以實證為基礎的腎臟科臨床決策知識庫。',
		url: 'https://nephrodecisions.com/about/',
		knowsAbout: ['Nephrology', 'Chronic Kidney Disease', 'Dialysis', 'SGLT2 inhibitors', 'GLP-1 receptor agonists', 'Finerenone', 'Mineralocorticoid receptor antagonists'],
	},
});
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={`關於 | ${SITE_TITLE}`} description="關於本站與作者" />
		<script type="application/ld+json" set:html={profileLd} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			h1 {
				font-size: 2em;
				margin-bottom: 1em;
			}
			h2 {
				font-size: 1.4em;
				margin-top: 2em;
				margin-bottom: 0.5em;
			}
			.author-info {
				font-size: 1.1em;
				font-weight: 600;
				color: rgb(var(--gray-dark));
				margin-bottom: 1.5em;
			}
			ol {
				padding-left: 1.5em;
			}
			ol li {
				margin-bottom: 0.5em;
			}
			.disclaimer {
				margin-top: 2.5em;
				padding: 1.2em;
				background: rgb(var(--gray-light));
				border-radius: 8px;
				font-size: 0.9em;
				color: rgb(var(--gray-dark));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>關於本站</h1>

			<p class="author-info">小鎮醫生｜腎臟科專科醫師｜內科專科醫師｜台灣大學醫學系</p>

			<p>
				Nephro Decisions 是腎臟科臨床決策知識庫，涵蓋 SGLT2 inhibitor、GLP-1 receptor agonist、透析照護、病人衛教與臨床專題等多元主題。
				每篇內容皆以實證為基礎，結合臨床情境設計，目標是讓腎臟科醫師與照護團隊在門診、病房與透析室中能快速參考、輔助判斷。
			</p>

			<h2>編輯流程（7 步驟）</h2>
			<ol>
				<li><strong>臨床題目</strong>——醫師從實際臨床困境提出具體決策問題</li>
				<li><strong>題目結構釐清</strong>——ChatGPT / Claude 協助拆解 sub-questions 與族群範圍</li>
				<li><strong>三源 Deep Research 提示詞建構</strong>——ChatGPT Deep Research 產生一致的研究 prompt</li>
				<li><strong>三源平行 Deep Research</strong>——ChatGPT + Claude + Gemini 各自獨立產出完整文獻回顧</li>
				<li><strong>Synthesis + Decision Note 產製</strong>——Claude Code 交叉比對三源，整合為結構化 synthesis 與 decision note（v1.0）</li>
				<li><strong>雙重審閱</strong>——醫師做臨床判斷與事實把關；ChatGPT Pro 做獨立查核與修訂（v1.1）</li>
				<li><strong>定稿上架</strong>——醫師拍板、標註版本號與更新日期</li>
			</ol>

			<p style="margin-top: 1em;">
				<a href="/editorial-policy/">完整編輯方針 →</a>
			</p>

			<h2>版本管理</h2>
			<p>
				每篇筆記標註版本號（v1.0、v1.1）與最後更新日期。當有重要指引更新或新證據發表時，將進行版本更新。
			</p>

			<div class="disclaimer" id="disclaimer">
				<strong>免責聲明：</strong>本站內容為個人臨床學習整理，不代表任何機構立場。臨床決策應結合個別病人狀況與最新指引。
				本站內容不構成醫療建議，不應取代專業醫師的臨床判斷。
			</div>
		</main>
		<Footer />
	</body>
</html>
