---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import FinerenoneLayout from '../../layouts/FinerenoneLayout.astro';

export async function getStaticPaths() {
	const notes = await getCollection('finerenone');
	return notes.map((note) => ({
		params: { slug: note.id },
		props: note,
	}));
}
type Props = CollectionEntry<'finerenone'>;

const note = Astro.props;
const { Content } = await render(note);
---

<FinerenoneLayout {...note.data}>
	<Content />
</FinerenoneLayout>
