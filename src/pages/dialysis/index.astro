---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const allArticles = await getCollection('dialysis');
const sorted = allArticles.sort((a, b) => a.data.chapter.localeCompare(b.data.chapter));
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={`透析衛教——護理版 | ${SITE_TITLE}`} description="以護理實務為導向的透析照護學習筆記，整合多本教科書的核心知識。" />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			h1 {
				font-size: 2em;
				margin-bottom: 0.3em;
			}
			.subtitle {
				color: rgb(var(--gray));
				font-size: 1.05em;
				margin-bottom: 2em;
			}
			.note-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.note-list li {
				padding: 0.5em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.note-list li:last-child {
				border-bottom: none;
			}
			.note-link {
				text-decoration: none;
				display: block;
			}
			.note-link:hover .note-title {
				color: var(--accent);
			}
			.note-title {
				font-weight: 600;
			}
			.note-id {
				font-weight: 700;
				color: var(--accent-dark);
				margin-right: 0.3em;
			}
			.note-meta {
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin-top: 0.2em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>透析衛教——護理版</h1>
			<p class="subtitle">以護理實務為導向的透析照護學習筆記，整合多本教科書的核心知識。</p>

			<ul class="note-list">
				{sorted.map((article) => (
					<li>
						<a class="note-link" href={`/dialysis/${article.id}/`}>
							<span class="note-title">
								<span class="note-id">{article.data.chapter}</span>
								{article.data.title}
							</span>
							<div class="note-meta">
								{article.data.category}
							</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
