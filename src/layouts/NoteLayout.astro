---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = (CollectionEntry<'sglt2i'>['data'] | CollectionEntry<'glp1ra'>['data'] | CollectionEntry<'sexualHealth'>['data']) & { extraSchema?: string | null };

const { question_id, title, category, version, last_updated, tags, description, seo_title, quick_answer, extraSchema } = Astro.props;

// Dynamic breadcrumb based on URL path
const path = Astro.url.pathname;
const breadcrumbMap: Record<string, { href: string; label: string }> = {
	'/sglt2i/': { href: '/sglt2i/', label: 'SGLT2i 決策筆記' },
	'/glp1ra/': { href: '/glp1ra/', label: 'GLP-1 RA 決策筆記' },
	'/sexual-health/': { href: '/sexual-health/', label: '腎友與性' },
};
const matchedSection = Object.entries(breadcrumbMap).find(([prefix]) => path.startsWith(prefix));
const breadcrumb = matchedSection ? matchedSection[1] : { href: '/sglt2i/', label: '決策筆記' };

const jsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': ['MedicalWebPage', 'Article'],
	name: title,
	dateModified: last_updated.toISOString(),
	author: {
		'@type': 'Person',
		name: '小鎮醫生',
		jobTitle: '腎臟科專科醫師',
		affiliation: {
			'@type': 'Organization',
			name: '台灣大學醫學系',
		},
		url: 'https://nephrodecisions.com/about/',
	},
	about: {
		'@type': 'MedicalCondition',
		name: 'Chronic Kidney Disease',
	},
});

const breadcrumbLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: '首頁', item: 'https://nephrodecisions.com/' },
		{ '@type': 'ListItem', position: 2, name: breadcrumb.label, item: `https://nephrodecisions.com${breadcrumb.href}` },
		{ '@type': 'ListItem', position: 3, name: question_id },
	],
});
---

<html lang="zh-Hant">
	<head>
		<BaseHead title={seo_title || `${title} — Nephro Decisions`} description={description || title} />
		<script type="application/ld+json" set:html={jsonLd} />
		<script type="application/ld+json" set:html={breadcrumbLd} />
		{extraSchema && <script type="application/ld+json" set:html={extraSchema} />}
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.breadcrumb {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 1em auto 0;
				padding: 0 1em;
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.breadcrumb a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumb a:hover {
				color: var(--accent);
			}
			.note-header {
				margin-bottom: 1.5em;
				padding-bottom: 1em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.note-header h1 {
				margin: 0 0 0.5em 0;
				font-size: 2em;
				line-height: 1.3;
			}
			.meta {
				display: flex;
				flex-wrap: wrap;
				gap: 1em;
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.meta-item {
				display: flex;
				align-items: center;
				gap: 0.3em;
			}
			.meta-label {
				font-weight: 700;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				margin-top: 0.5em;
			}
			.tag {
				background: rgb(var(--gray-light));
				padding: 0.15em 0.6em;
				border-radius: 4px;
				font-size: 0.8em;
				color: rgb(var(--gray-dark));
			}
			.quick-answer {
				background: var(--accent-light, #e8f4f0);
				border-left: 4px solid var(--accent);
				padding: 1em 1.2em;
				margin-bottom: 1.5em;
				border-radius: 0 6px 6px 0;
				font-size: 0.95em;
				line-height: 1.6;
			}
			.quick-answer strong {
				color: var(--accent-dark);
			}
			.author-block {
				display: flex;
				gap: 1em;
				align-items: flex-start;
				margin-top: 3em;
				padding: 1.5em;
				background: #f8f9fa;
				border-radius: 10px;
				border: 1px solid rgb(var(--gray-light));
			}
			.author-avatar {
				font-size: 2.5em;
				flex-shrink: 0;
			}
			.author-info {
				font-size: 0.88em;
				line-height: 1.6;
				color: rgb(var(--gray));
			}
			.author-info p {
				margin: 0 0 0.2em;
			}
			.author-name {
				font-size: 1.1em;
				font-weight: 700;
				color: rgb(var(--gray-dark));
			}
			.author-title {
				color: var(--accent-dark);
				font-weight: 500;
			}
			.author-ai {
				font-size: 0.85em;
				font-style: italic;
			}
			.author-link {
				display: inline-block;
				margin-top: 0.4em;
				color: var(--accent);
				text-decoration: none;
				font-weight: 600;
				font-size: 0.9em;
			}
			.author-link:hover {
				text-decoration: underline;
			}
			.print-btn-wrapper {
				margin-bottom: 1.5em;
				text-align: right;
			}
			.print-btn {
				padding: 0.4em 1em;
				background: rgb(var(--gray-light));
				border: 1px solid rgb(var(--gray-light));
				border-radius: 6px;
				font-size: 0.85em;
				color: rgb(var(--gray-dark));
				cursor: pointer;
			}
			.print-btn:hover {
				background: #ddd;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<nav class="breadcrumb">
				<a href="/">首頁</a> &rsaquo;
				<a href={breadcrumb.href}>{breadcrumb.label}</a> &rsaquo;
				<span>{question_id}</span>
			</nav>
			<article class="prose">
				<div class="note-header">
					<h1>{question_id} — {title}</h1>
					<div class="meta">
						<span class="meta-item">
							<span class="meta-label">分類：</span>{category}
						</span>
						<span class="meta-item">
							<span class="meta-label">版本：</span>{version}
						</span>
						<span class="meta-item">
							<span class="meta-label">更新日期：</span><FormattedDate date={last_updated} />
						</span>
					</div>
				</div>
				<div class="print-btn-wrapper">
					<button class="print-btn" onclick="window.print()">列印 / 存 PDF</button>
				</div>
				{quick_answer && (
					<div class="quick-answer">
						<strong>臨床結論：</strong>{quick_answer}
					</div>
				)}
				<slot />
				<aside class="author-block">
					<div class="author-avatar">👨‍⚕️</div>
					<div class="author-info">
						<p class="author-name">小鎮醫生</p>
						<p class="author-title">腎臟科專科醫師｜內科專科醫師</p>
						<p class="author-review">醫師審閱：<FormattedDate date={last_updated} /></p>
						<p class="author-ai">AI 輔助：文獻搜尋與初稿整理。最終內容由醫師查核與修訂。</p>
						<a class="author-link" href="/about/">了解編輯流程 →</a>
					</div>
				</aside>
				<div class="print-footer">
					<p>Nephro Decisions｜nephrodecisions.com｜由腎臟科專科醫師主導，AI 輔助研究與多輪交替審稿。本文不構成醫療建議。</p>
				</div>
			</article>
		</main>
		<Footer />
		<script>
			document.querySelectorAll('.prose table').forEach((table) => {
				if (!table.parentElement?.classList.contains('table-wrapper')) {
					const wrapper = document.createElement('div');
					wrapper.className = 'table-wrapper';
					table.parentNode?.insertBefore(wrapper, table);
					wrapper.appendChild(table);
				}
			});
		</script>
	</body>
</html>
