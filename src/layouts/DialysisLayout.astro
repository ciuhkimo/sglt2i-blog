---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'dialysis'>['data'];

const { title, chapter, category, target_audience, last_updated } = Astro.props;

const jsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'MedicalWebPage',
	name: title,
	dateModified: last_updated.toISOString(),
	author: {
		'@type': 'Person',
		name: '小鎮醫生',
		jobTitle: '腎臟科專科醫師',
	},
	audience: {
		'@type': 'MedicalAudience',
		audienceType: 'Nurse',
	},
	about: {
		'@type': 'MedicalCondition',
		name: 'End-Stage Renal Disease',
	},
});
---

<html lang="zh-Hant">
	<head>
		<BaseHead title={`${title} — 透析衛教`} description={title} />
		<script type="application/ld+json" set:html={jsonLd} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.breadcrumb {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 1em auto 0;
				padding: 0 1em;
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.breadcrumb a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumb a:hover {
				color: var(--accent);
			}
			.note-header {
				margin-bottom: 1.5em;
				padding-bottom: 1em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.note-header h1 {
				margin: 0 0 0.5em 0;
				font-size: 2em;
				line-height: 1.3;
			}
			.meta {
				display: flex;
				flex-wrap: wrap;
				gap: 1em;
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.meta-item {
				display: flex;
				align-items: center;
				gap: 0.3em;
			}
			.meta-label {
				font-weight: 700;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<nav class="breadcrumb">
				<a href="/">首頁</a> &rsaquo;
				<a href="/dialysis/">透析衛教</a> &rsaquo;
				<span>{title}</span>
			</nav>
			<article class="prose">
				<div class="note-header">
					<h1>{chapter} — {title}</h1>
					<div class="meta">
						<span class="meta-item">
							<span class="meta-label">分類：</span>{category}
						</span>
						<span class="meta-item">
							<span class="meta-label">對象：</span>{target_audience}
						</span>
						<span class="meta-item">
							<span class="meta-label">更新日期：</span><FormattedDate date={last_updated} />
						</span>
					</div>
				</div>
				<slot />
			</article>
		</main>
		<Footer />
		<script>
			document.querySelectorAll('.prose table').forEach((table) => {
				if (!table.parentElement?.classList.contains('table-wrapper')) {
					const wrapper = document.createElement('div');
					wrapper.className = 'table-wrapper';
					table.parentNode?.insertBefore(wrapper, table);
					wrapper.appendChild(table);
				}
			});
		</script>
	</body>
</html>
