---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, category, target_audience, last_updated, description, seo_title, tags } = Astro.props;

const jsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': ['MedicalWebPage', 'Article'],
	name: title,
	dateModified: last_updated.toISOString(),
	author: {
		'@type': 'Person',
		name: '小鎮醫生',
		jobTitle: '腎臟科專科醫師',
		affiliation: {
			'@type': 'Organization',
			name: '台灣大學醫學系',
		},
		url: 'https://nephrodecisions.com/about/',
	},
});

const breadcrumbLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: '首頁', item: 'https://nephrodecisions.com/' },
		{ '@type': 'ListItem', position: 2, name: '臨床專題', item: 'https://nephrodecisions.com/blog/' },
		{ '@type': 'ListItem', position: 3, name: title },
	],
});
---

<html lang="zh-Hant">
	<head>
		<BaseHead title={seo_title || `${title} — 臨床專題`} description={description || title} />
		<script type="application/ld+json" set:html={jsonLd} />
		<script type="application/ld+json" set:html={breadcrumbLd} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.breadcrumb {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 1em auto 0;
				padding: 0 1em;
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.breadcrumb a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumb a:hover {
				color: var(--accent);
			}
			.blog-header {
				margin-bottom: 1.5em;
				padding-bottom: 1em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.blog-header h1 {
				margin: 0 0 0.5em 0;
				font-size: 2em;
				line-height: 1.3;
			}
			.meta {
				display: flex;
				flex-wrap: wrap;
				gap: 1em;
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.meta-item {
				display: flex;
				align-items: center;
				gap: 0.3em;
			}
			.meta-label {
				font-weight: 700;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				margin-top: 0.5em;
			}
			.tag {
				background: rgb(var(--gray-light));
				padding: 0.15em 0.6em;
				border-radius: 4px;
				font-size: 0.8em;
				color: rgb(var(--gray-dark));
			}
			.print-btn-wrapper {
				margin-bottom: 1.5em;
				text-align: right;
			}
			.print-btn {
				padding: 0.4em 1em;
				background: rgb(var(--gray-light));
				border: 1px solid rgb(var(--gray-light));
				border-radius: 6px;
				font-size: 0.85em;
				color: rgb(var(--gray-dark));
				cursor: pointer;
			}
			.print-btn:hover {
				background: #ddd;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<nav class="breadcrumb">
				<a href="/">首頁</a> &rsaquo;
				<a href="/blog/">臨床專題</a> &rsaquo;
				<span>{title}</span>
			</nav>
			<article class="prose">
				<div class="blog-header">
					<h1>{title}</h1>
					<div class="meta">
						<span class="meta-item">
							<span class="meta-label">分類：</span>{category}
						</span>
						<span class="meta-item">
							<span class="meta-label">對象：</span>{target_audience}
						</span>
						<span class="meta-item">
							<span class="meta-label">更新日期：</span><FormattedDate date={last_updated} />
						</span>
					</div>
				</div>
				<div class="print-btn-wrapper">
					<button class="print-btn" onclick="window.print()">列印 / 存 PDF</button>
				</div>
				<slot />
				<div class="print-footer">
					<p>Nephro Decisions｜nephrodecisions.com｜由腎臟科專科醫師主導，AI 輔助研究與多輪交替審稿。本文不構成醫療建議。</p>
				</div>
			</article>
		</main>
		<Footer />
		<script>
			document.querySelectorAll('.prose table').forEach((table) => {
				if (!table.parentElement?.classList.contains('table-wrapper')) {
					const wrapper = document.createElement('div');
					wrapper.className = 'table-wrapper';
					table.parentNode?.insertBefore(wrapper, table);
					wrapper.appendChild(table);
				}
			});
		</script>
	</body>
</html>
