---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'patient'>['data'];

const { title, description, source_note, last_updated, tags, seo_title } = Astro.props;

const jsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'MedicalWebPage',
	name: title,
	dateModified: last_updated.toISOString(),
	audience: {
		'@type': 'PeopleAudience',
		audienceType: 'Patient',
	},
	author: {
		'@type': 'Person',
		name: '張育興',
		jobTitle: '腎臟科專科醫師',
	},
	about: {
		'@type': 'MedicalCondition',
		name: 'Chronic Kidney Disease',
	},
});
---

<html lang="zh-Hant">
	<head>
		<BaseHead title={seo_title || `${title} — 病人衛教`} description={description} />
		<script type="application/ld+json" set:html={jsonLd} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
				font-size: 1.1em;
				line-height: 1.9;
			}
			.breadcrumb {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 1em auto 0;
				padding: 0 1em;
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.breadcrumb a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumb a:hover {
				color: var(--accent);
			}
			.article-header {
				margin-bottom: 1.5em;
				padding-bottom: 1em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.article-header h1 {
				margin: 0 0 0.5em 0;
				font-size: 2em;
				line-height: 1.3;
			}
			.meta {
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.callout {
				background: #fef9ef;
				border-left: 4px solid #e6a817;
				padding: 1em 1.2em;
				margin-bottom: 1.5em;
				border-radius: 0 6px 6px 0;
				font-size: 0.95em;
				line-height: 1.7;
			}
			.pro-link {
				margin-top: 2em;
				padding-top: 1.5em;
				border-top: 1px solid rgb(var(--gray-light));
				font-size: 0.9em;
			}
			.pro-link a {
				color: var(--accent);
				text-decoration: none;
			}
			.pro-link a:hover {
				text-decoration: underline;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				margin-top: 0.8em;
			}
			.tag {
				background: rgb(var(--gray-light));
				padding: 0.15em 0.6em;
				border-radius: 4px;
				font-size: 0.75em;
				color: rgb(var(--gray-dark));
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<nav class="breadcrumb">
				<a href="/">首頁</a> &rsaquo;
				<a href="/patient/">給病人與家屬</a> &rsaquo;
				<span>{title}</span>
			</nav>
			<article class="prose">
				<div class="article-header">
					<h1>{title}</h1>
					<div class="meta">
						更新日期：<FormattedDate date={last_updated} />
					</div>
				</div>
				<div class="callout">
					這篇文章幫助您了解醫師處方的藥物。具體用藥請遵循您的主治醫師指示。
				</div>
				<slot />
				<div class="pro-link">
					<a href={`/notes/${source_note}/`}>醫療專業人員版本 &rarr;</a>
				</div>
				{tags.length > 0 && (
					<div class="tags">
						{tags.map((tag) => (
							<span class="tag">{tag}</span>
						))}
					</div>
				)}
			</article>
		</main>
		<Footer />
	</body>
</html>
