---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'patient'>['data'];

const { title, description, source_note, last_updated, tags, seo_title } = Astro.props;

const noteSlugMap: Record<string, string> = {
	Q01: 'q01-ckd-start-timing',
	Q02: 'q02-nondm-ckd',
	Q03: 'q03-proteinuria-impact',
	Q04: 'q04-egfr-20-30-threshold',
	Q05: 'q05-renal-vs-hf-protection',
	Q06: 'q06-volume-status-assessment',
	Q07: 'q07-dka-risk-identification',
	Q08: 'q08-recurrent-infection',
	Q09: 'q09-surgery-fasting-hold',
	Q10: 'q10-creatinine-dip-vs-aki',
	Q11: 'q11-egfr-decline-acceptable',
	Q12: 'q12-hypotension-attribution',
	Q13: 'q13-polyuria-dehydration',
	Q14: 'q14-acute-illness-hold',
	Q15: 'q15-aki-stop-decision',
	Q16: 'q16-perioperative-timing',
	Q17: 'q17-aki-recovery-restart',
	Q18: 'q18-postop-restart',
	Q19: 'q19-drug-combination-strategy',
	Q20: 'q20-special-populations',
};
const noteSlug = source_note ? (noteSlugMap[source_note] || source_note.toLowerCase()) : '';

const jsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': ['MedicalWebPage', 'Article'],
	name: title,
	dateModified: last_updated.toISOString(),
	audience: {
		'@type': 'PeopleAudience',
		audienceType: 'Patient',
	},
	author: {
		'@type': 'Person',
		name: '小鎮醫生',
		jobTitle: '腎臟科專科醫師',
		affiliation: {
			'@type': 'Organization',
			name: '台灣大學醫學系',
		},
		url: 'https://nephrodecisions.com/about/',
	},
	about: {
		'@type': 'MedicalCondition',
		name: 'Chronic Kidney Disease',
	},
});

const breadcrumbLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: '首頁', item: 'https://nephrodecisions.com/' },
		{ '@type': 'ListItem', position: 2, name: '給病人與家屬', item: 'https://nephrodecisions.com/patient/' },
		{ '@type': 'ListItem', position: 3, name: title },
	],
});
---

<html lang="zh-Hant">
	<head>
		<BaseHead title={seo_title || `${title} — 病人衛教`} description={description} />
		<script type="application/ld+json" set:html={jsonLd} />
		<script type="application/ld+json" set:html={breadcrumbLd} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
				font-size: 1.1em;
				line-height: 1.9;
			}
			.breadcrumb {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 1em auto 0;
				padding: 0 1em;
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.breadcrumb a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.breadcrumb a:hover {
				color: var(--accent);
			}
			.article-header {
				margin-bottom: 1.5em;
				padding-bottom: 1em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.article-header h1 {
				margin: 0 0 0.5em 0;
				font-size: 2em;
				line-height: 1.3;
			}
			.meta {
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
			.callout {
				background: #fef9ef;
				border-left: 4px solid #e6a817;
				padding: 1em 1.2em;
				margin-bottom: 1.5em;
				border-radius: 0 6px 6px 0;
				font-size: 0.95em;
				line-height: 1.7;
			}
			.pro-link {
				margin-top: 2em;
				padding-top: 1.5em;
				border-top: 1px solid rgb(var(--gray-light));
				font-size: 0.9em;
			}
			.pro-link a {
				color: var(--accent);
				text-decoration: none;
			}
			.pro-link a:hover {
				text-decoration: underline;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				margin-top: 0.8em;
			}
			.tag {
				background: rgb(var(--gray-light));
				padding: 0.15em 0.6em;
				border-radius: 4px;
				font-size: 0.75em;
				color: rgb(var(--gray-dark));
			}
			.print-btn-wrapper {
				margin-bottom: 1.5em;
				text-align: right;
			}
			.print-btn {
				padding: 0.4em 1em;
				background: rgb(var(--gray-light));
				border: 1px solid rgb(var(--gray-light));
				border-radius: 6px;
				font-size: 0.85em;
				color: rgb(var(--gray-dark));
				cursor: pointer;
			}
			.print-btn:hover {
				background: #ddd;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<nav class="breadcrumb">
				<a href="/">首頁</a> &rsaquo;
				<a href="/patient/">給病人與家屬</a> &rsaquo;
				<span>{title}</span>
			</nav>
			<article class="prose">
				<div class="article-header">
					<h1>{title}</h1>
					<div class="meta">
						更新日期：<FormattedDate date={last_updated} />
					</div>
				</div>
				<div class="callout">
					這篇文章幫助您了解醫師處方的藥物。具體用藥請遵循您的主治醫師指示。
				</div>
				<div class="print-btn-wrapper">
					<button class="print-btn" onclick="window.print()">列印 / 存 PDF</button>
				</div>
				<slot />
				{source_note && (
					<div class="pro-link">
						<a href={`/sglt2i/${noteSlug}/`}>醫療專業人員版本 &rarr;</a>
					</div>
				)}
				{tags.length > 0 && (
					<div class="tags">
						{tags.map((tag) => (
							<span class="tag">{tag}</span>
						))}
					</div>
				)}
				<div class="print-footer">
					<p>Nephro Decisions｜nephrodecisions.com｜由腎臟科專科醫師主導，AI 輔助研究與多輪交替審稿。本文不構成醫療建議。</p>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
