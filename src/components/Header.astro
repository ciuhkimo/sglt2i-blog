---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">首頁</HeaderLink>
			<HeaderLink href="/sglt2i">SGLT2i</HeaderLink>
			<HeaderLink href="/glp1ra">GLP-1 RA</HeaderLink>
			<HeaderLink href="/patient">給病人與家屬</HeaderLink>
			<HeaderLink href="/dialysis">透析衛教</HeaderLink>
			<HeaderLink href="/blog">臨床專題</HeaderLink>
			<HeaderLink href="/about">關於</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--accent-dark);
		box-shadow: 0 2px 8px rgba(var(--black), 10%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #fff;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgba(255, 255, 255, 0.8);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a:hover {
		color: #fff;
	}
	nav a.active {
		text-decoration: none;
		color: #fff;
		border-bottom-color: var(--accent-light, #e8f4f0);
	}
</style>
